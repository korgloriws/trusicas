# Copy to .env and fill in. Never commit .env.

OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Pool de modelos gratuitos (vírgulas). Em cada geração o OpenRouter escolhe o mais
# disponível/rápido no momento (não fica preso ao primeiro da lista).
# Nota: openai/gpt-oss-120b:free NÃO existe no OpenRouter — use openai/gpt-oss-20b:free.
OPENROUTER_MODELS=nvidia/nemotron-3-super-120b-a12b:free,qwen/qwen3-coder:free,openai/gpt-oss-20b:free,tencent/hy3:free,nvidia/nemotron-3-ultra-550b-a55b:free

# Opcional: se OPENROUTER_MODELS estiver vazio, usa só este modelo.
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Critério de escolha entre o pool: throughput (default, melhor p/ lições longas) | latency | price
OPENROUTER_ROUTE_SORT=throughput

# Optional: shown on OpenRouter rankings (https://openrouter.ai/docs#request-headers)
OPENROUTER_HTTP_REFERER=https://localhost
OPENROUTER_X_TITLE=trusicas

# Optional: ask the API for JSON mode (not supported by every free model; leave false if you get errors)
OPENROUTER_JSON_MODE=false

TEMPERATURE=0.25
OPENROUTER_TIMEOUT_S=120

# Máximo de tokens de SAÍDA por pedido (max_tokens). Default no código: 32768. Valores muito altos podem dar HTTP 400 na API.
# O teto enviado ao OpenRouter fica limitado (ver OPENROUTER_MAX_TOKENS_REQUEST_CAP em config.py).
OPENROUTER_MAX_OUTPUT_TOKENS=32768

# Caminho opcional do SQLite (default: data/lessons.sqlite nesta pasta)
# TRUSICAS_DB=C:\caminho\lessons.sqlite

# Conta admin inicial (criada automaticamente na 1.ª arranque se não existir admin)
TRUSICAS_ADMIN_USERNAME=admin
TRUSICAS_ADMIN_PASSWORD=Senha
# TRUSICAS_ADMIN_DISPLAY_NAME=Administrador

# Chave para assinar a sessão (gere uma string longa aleatória)
TRUSICAS_SECRET_KEY=mude-isto-para-uma-string-aleatoria-longa

# Duração da sessão em horas (default 168 = 7 dias)
# TRUSICAS_ADMIN_SESSION_HOURS=168

# Docker / produção (docker-compose já define FLASK_HOST e PORT)
# OPENROUTER_HTTP_REFERER=http://31.97.167.75:5090
